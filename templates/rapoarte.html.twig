{% extends 'base.html.twig' %}
{% set nonceScript = csp_nonce('script') %}
{% block tableTitle %}Rapoarte plati medici colaboratori{% endblock %}
{% block table %}
    <table class="table table-bordered rounded dataTable display nowrap" id="rapoarte_colaboratori" width="100%" cellspacing="0" role="grid" aria-describedby="dataTable_info"></table>
{% endblock %}
{% if app.user.getRole() != 'ROLE_Administrator' %}
    {% set class = 'no_show' %}
{% else %}
    {% set class = 'add_raport_colaboratori' %}
{% endif %}
{% block classAddBtn %}{{ class }}{% endblock %}
{% block addBtnText %}Genereaza{% endblock %}
{% block addModal %}
    {% include 'modals/add_raport_colaboratori_modal.html.twig' %}
    {% include 'modals/plateste_colaborator_modal.html.twig' %}
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('assets/js/rapoarte.js') }}" nonce="{{ nonceScript }}"></script>
{% endblock %}