<div class="modal-header">
    <h5 class="modal-title titlu_modal_serviciu_cons" id="titlu_consultatie">Editeaza consultatie - {{ data.denumireServiciu ?? '' }}</h5>
    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
        <span>&times;</span>
    </button>
</div>
<div class="modal-body cons" style="height: 630px;">
    {% set TIP_CONSULTATIE = 0 %}
    <div class="row">
        <div class="col-sm-1" id="istoric_pacient_cons"><b>ISTORIC</b>
            <div class="btn-group istoric_btn" style="margin-top: 10px;">
                <a class="btn btn-sm btn-success istoric_a">Consultatii</a>
                <button type="button" class="istoric_consultatii_cons btn btn-sm btn-success dropdown-toggle dropdown-toggle-split" data-toggle="dropdown"></button>
                <div class="dropdown-menu dropdown_consultatii_cons"></div>
            </div>
            <div class="btn-group istoric_btn">
                <a class="btn btn-sm btn-primary istoric_a">Investigatii</a>
                <button type="button" class="istoric_investigatii_cons btn btn-sm btn-primary dropdown-toggle dropdown-toggle-split" data-toggle="dropdown"></button>
                <div class="dropdown-menu dropdown_investigatii_cons"></div>
            </div>
            <div class="btn-group istoric_btn">
                <a class="btn btn-sm btn-secondary istoric_a" style="width: 85.58px;">Toate</a>
                <button type="button" class="istoric_toate_cons btn btn-sm btn-secondary dropdown-toggle dropdown-toggle-split" data-toggle="dropdown"></button>
                <div class="dropdown-menu dropdown_toate_cons"></div>
            </div>
        </div>
        <div class="col-sm-11">
            <form id="consultatie_form">
                <div class="form-group row">
                    <div class="col-sm-2 mb-3 mb-sm-0">
                        <label for="consultatie_nrInreg">Numar inregistrare</label>
                        <input type="text" class="form-control" id="consultatie_nrInreg" name="consultatie_nrInreg" value="{{ data.nrInreg ?? '' }}" />
                    </div>
                    <div class="col-sm-4 mb-3 mb-sm-0">
                        <label for="consultatie_pacient_name">Pacient</label>
                        <input type="text" class="form-control" id="consultatie_pacient_name" name="consultatie_pacient_name" value="{{ data.numePacient ?? '' }}" disabled />
                        <input type="hidden" id="consultatie_pacient" name="consultatie_pacient" value="{{ data.pacientId ?? '' }}">
                    </div>
                    <div class="col-sm-1 mb-3 mb-sm-0">
                        <label for="consultatie_sex">Sex</label>
                        <input type="text" class="form-control" id="consultatie_sex" name="consultatie_sex" value="{{ data.sex ?? '' }}" disabled />
                    </div>
                    <div class="col-sm-2 mb-3 mb-sm-0">
                        <label for="consultatie_dataNasterii">Data nasterii</label>
                        <input type="text" class="form-control" id="consultatie_dataNasterii" name="consultatie_dataNasterii" value="{{ data.dataNasterii ?? '' }}" disabled />
                    </div>
                    <div class="col-sm-3 mb-3 mb-sm-0">
                        <label for="consultatie_cnp">CNP / CI</label>
                        <input type="text" class="form-control" id="consultatie_cnp" name="consultatie_cnp" value="{{ data.cnp ?? '' }}" disabled />
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-sm-4 dropdown show">
                        <label for="consultatie_medic">Medic</label>
                        <select type="text" class="form-control" id="consultatie_medic" name="consultatie_medic" disabled>
                            <option value="">- Alegeti -</option>
                            {% for medic in medici %}
                                <option value="{{ medic.id }}"
                                        {{ data.medicId|default('') == medic.id ? 'selected' }}>
                                    {{ medic.nume }} {{ medic.prenume }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-sm-4 dropdown show">
                        <label for="consultatie_serviciu">Serviciu</label>
                        <select type="text" class="form-control" id="consultatie_serviciu" name="consultatie_serviciu" disabled>
                            <option value="">- Alegeti -</option>
                            {% for serviciu in servicii %}
                                {% if serviciu.tip == TIP_CONSULTATIE %}
                                    <option value="{{ serviciu.id }}"
                                            {{ data.serviciuId|default('') == serviciu.id ? 'selected' }}>
                                        {{ serviciu.denumire }}
                                    </option>
                                {% endif %}
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-sm-4 dropdown show">
                        <label for="consultatie_owner">Owner</label>
                        <select type="text" class="form-control" id="consultatie_owner" name="consultatie_owner" disabled>
                            <option value="">- Alegeti -</option>
                            {% for owner in owners %}
                                <option value="{{ owner.id }}"
                                        {{ data.ownerId|default('') == owner.id ? 'selected' }}>
                                    {{ owner.denumire }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-sm-12 mb-3 mb-sm-0">
                        <label for="consultatie_diagnostic">Diagnostic *</label>
                        <textarea class="form-control" id="consultatie_diagnostic" name="consultatie_diagnostic">{{ data.diagnostic ?? '' }}</textarea>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-sm-12 mb-3 mb-sm-0">
                        <label for="consultatie_ahc">AHC</label>
                        <textarea class="form-control" id="consultatie_ahc" name="consultatie_ahc">{{ data.ahc ?? '' }}</textarea>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-sm-12 mb-3 mb-sm-0">
                        <label for="consultatie_app">APP</label>
                        <textarea class="form-control" id="consultatie_app" name="consultatie_app">{{ data.app ?? '' }}</textarea>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-sm-12 mb-3 mb-sm-0">
                        <label for="consultatie_consultatie">Consultatie *</label>
                        <textarea class="form-control" id="consultatie_consultatie" name="consultatie_consultatie">{{ data.consultatie ?? '' }}</textarea>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-sm-12 mb-3 mb-sm-0">
                        <label for="consultatie_tratament">Recomandari si tratament *</label>
                        <textarea class="form-control" id="consultatie_tratament" name="consultatie_tratament">{{ data.tratament ?? '' }}</textarea>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-sm-12 mb-3 mb-sm-0">
                        <label for="consultatie_investigatiiUrmate">Investigatii urmate</label>
                        <textarea class="form-control" id="consultatie_investigatiiUrmate" name="consultatie_investigatiiUrmate">{{ data.investigatiiUrmate ?? '' }}</textarea>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-sm-12 mb-3 mb-sm-0">
                        <label for="consultatie_tratamenteUrmate">Tratamente urmate</label>
                        <textarea class="form-control" id="consultatie_tratamenteUrmate" name="consultatie_tratamenteUrmate">{{ data.tratamenteUrmate ?? '' }}</textarea>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-sm-12 mb-3 mb-sm-0">
                        <label for="consultatie_observatii">Observatii</label>
                        <textarea class="form-control" id="consultatie_observatii" name="consultatie_observatii">{{ data.observatii ?? '' }}</textarea>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-sm-3 mb-3 mb-sm-0">
                        <label for="consultatie_loc">Locul consultatiei</label>
                        <select type="text" class="form-control" id="consultatie_loc" name="consultatie_loc">
                            <option value="C" {{ data.loc is defined and data.loc == 'C' ? 'selected' }}>Cabinet</option>
                            <option value="D" {{ data.loc is defined and data.loc == 'D' ? 'selected' }}>Domiciliu</option>
                        </select>
                    </div>
                    <div class="col-sm-3 mb-3 mb-sm-0">
                        <label for="consultatie_medicTrimitator">Medic trimitator (cauta sau introdu)</label>
                        <div class="input-group date">
                            <input list="list_cons" class="form-control" id="consultatie_medicTrimitator" name="consultatie_medicTrimitator" placeholder="Nume si cod parafa" value="{{ data.medicTrimitator|default('') }}" />
                            <span id="list_all_cons" class="input-group-append"><span class="input-group-text"><i class="fa fa-arrow-circle-down"></i></span></span>
                            <datalist id="list_cons">
                                {% for medicTrimitator in mediciTrimitatori %}
                                    <option value="{{ medicTrimitator.nume }}"
                                            {{ data.medicTrimitator|default('') == medicTrimitator.nume ? 'selected' }}>
                                        {{ medicTrimitator.nume }}
                                    </option>
                                {% endfor %}
                            </datalist>
                        </div>
                    </div>
                    <div class="col-sm-3 mb-3 mb-sm-0"></div>
                    <div class="col-sm-3 mb-3 mb-sm-0"></div>
                </div>
                <input type="hidden" id="consultatie_id" name="consultatie_id" value="{{ data.id ?? '' }}" />
                <input type="hidden" id="consultatie_pret" name="consultatie_pret" value="{{ data.pretId ?? '' }}" />
            </form>
        </div>
    </div>
</div>
<div class="modal-footer" style="margin-right: 25px;">
    <p class="modal-body rezultat_operatiune" style="display: none; margin-top: 10px; margin-bottom: 10px; font-weight: bold;"></p>
    <label style="text-align: right; color: #AA3333; font-weight: bold;" for="tarif_consultatie">Tarif consultatie</label>
    <input style="width: 55px; border: 1px solid #AA3333; border-radius:5px; text-align: right; font-weight: bold; color: black;" id="tarif_consultatie" name="tarif_consultatie" class="input_tarif" value="{{ data.tarif ?? '0' }}"/>
    <p style="color: black; margin-right: 10px; margin-left: 5px; border: none;"><b>RON</b></p>
    <button type="button" class="btn btn-primary confirma_consultatie btn_confirma confirma_cons_from_pacient">Salveaza
        <span class="spinner-border spinner-border-sm spinner" style="display: none;"></span>
    </button>
    <button type="button" class="btn btn-secondary" data-dismiss="modal">Anuleaza</button>
</div>