<div class="modal-header">
    <h5 class="modal-title titlu_modal_serviciu_inv" id="titlu_investigatie">Editeaza investigatie - {{ data.denumireServiciu ?? '' }}</h5>
    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
        <span>&times;</span>
    </button>
</div>
<div class="modal-body inv" style="height: 610px;">
    {% set TIP_INVESTIGATIE = 1 %}
    <div class="row">
        <div class="col-sm-1" id="istoric_pacient_inv"><b>ISTORIC</b>
            <div class="btn-group istoric_btn" style="margin-top: 10px;">
                <a class="btn btn-sm btn-success istoric_a">Consultatii</a>
                <button type="button" class="istoric_consultatii_inv btn btn-sm btn-success dropdown-toggle dropdown-toggle-split" data-toggle="dropdown"></button>
                <div class="dropdown-menu dropdown_consultatii_inv"></div>
            </div>
            <div class="btn-group istoric_btn">
                <a class="btn btn-sm btn-primary istoric_a">Investigatii</a>
                <button type="button" class="istoric_investigatii_inv btn btn-sm btn-primary dropdown-toggle dropdown-toggle-split" data-toggle="dropdown"></button>
                <div class="dropdown-menu dropdown_investigatii_inv"></div>
            </div>
            <div class="btn-group istoric_btn">
                <a class="btn btn-sm btn-secondary istoric_a" style="width: 85.58px;">Toate</a>
                <button type="button" class="istoric_toate_inv btn btn-sm btn-secondary dropdown-toggle dropdown-toggle-split" data-toggle="dropdown"></button>
                <div class="dropdown-menu dropdown_toate_inv"></div>
            </div>
        </div>
        <div class="col-sm-11">
            <form id="investigatie_form">
                <div class="form-group row">
                    <div class="col-sm-2 mb-3 mb-sm-0">
                        <label for="investigatie_nrInreg">Numar inregistrare</label>
                        <input type="text" class="form-control" id="investigatie_nrInreg" name="investigatie_nrInreg" value="{{ data.nrInreg ?? '' }}">
                    </div>
                    <div class="col-sm-4 mb-3 mb-sm-0">
                        <label for="investigatie_pacient_name">Pacient</label>
                        <input type="text" class="form-control" id="investigatie_pacient_name" name="investigatie_pacient_name" value="{{ data.numePacient ?? '' }}" disabled/>
                        <input type="hidden" id="investigatie_pacient" name="investigatie_pacient" value="{{ data.pacientId ?? '' }}">
                    </div>
                    <div class="col-sm-1 mb-3 mb-sm-0">
                        <label for="investigatie_sex">Sex</label>
                        <input type="text" class="form-control" id="investigatie_sex" name="investigatie_sex" value="{{ data.sex ?? '' }}" disabled />
                    </div>
                    <div class="col-sm-2 mb-3 mb-sm-0">
                        <label for="investigatie_dataNasterii">Data nasterii</label>
                        <input type="text" class="form-control" id="investigatie_dataNasterii" name="investigatie_dataNasterii" value="{{ data.dataNasterii ?? '' }}" disabled />
                    </div>
                    <div class="col-sm-3 mb-3 mb-sm-0">
                        <label for="investigatie_cnp">CNP / CI</label>
                        <input type="text" class="form-control" id="investigatie_cnp" name="investigatie_cnp" value="{{ data.cnp ?? '' }}" disabled />
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-sm-4 dropdown show">
                        <label for="investigatie_medic">Medic</label>
                        <select type="text" class="form-control" id="investigatie_medic" name="investigatie_medic" disabled>
                            {% for medic in medici %}
                                <option value="{{ medic.id }}"
                                        {{ data.medicId|default('') == medic.id ? 'selected' }}>
                                    {{ medic.nume }} {{ medic.prenume }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-sm-4 dropdown show">
                        <label for="investigatie_serviciu">Serviciu</label>
                        <select type="text" class="form-control" id="investigatie_serviciu" name="investigatie_serviciu" disabled>
                            <option value="">- Alegeti -</option>
                            {% for serviciu in servicii %}
                                {% if serviciu.tip == TIP_INVESTIGATIE %}
                                    <option value="{{ serviciu.id }}"
                                            {{ data.serviciuId|default('') == serviciu.id ? 'selected' }}>
                                        {{ serviciu.denumire }}
                                    </option>
                                {% endif %}
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-sm-4 dropdown show">
                        <label for="investigatie_owner">Owner</label>
                        <select type="text" class="form-control" id="investigatie_owner" name="investigatie_owner" disabled>
                            <option value="">- Alegeti -</option>
                            {% for owner in owners %}
                                <option value="{{ owner.id }}"
                                        {{ data.ownerId|default('') == owner.id ? 'selected' }}>
                                    {{ owner.denumire }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-sm-12 mb-3 mb-sm-0">
                        <label for="investigatie_ahc">AHC</label>
                        <textarea class="form-control" id="investigatie_ahc" name="investigatie_ahc">{{ data.ahc ?? '' }}</textarea>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-sm-12 mb-3 mb-sm-0">
                        <label for="investigatie_app">APP</label>
                        <textarea class="form-control" id="investigatie_app" name="investigatie_app">{{ data.app ?? '' }}</textarea>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-sm-12 mb-3 mb-sm-0">
                        <label for="investigatie_rezultat">Rezultat investigatie *</label>
                        <textarea style="height: 110px;" class="form-control" id="investigatie_rezultat" name="investigatie_rezultat">{{ data.consultatie ?? '' }}</textarea>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-sm-12 mb-3 mb-sm-0">
                        <label for="investigatie_concluzie">Concluzie *</label>
                        <textarea style="height: 110px;" class="form-control" id="investigatie_concluzie" name="investigatie_concluzie">{{ data.tratament ?? '' }}</textarea>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-sm-3 mb-3 mb-sm-0">
                        <label for="investigatie_loc">Locul consultatiei</label>
                        <select type="text" class="form-control" id="investigatie_loc" name="investigatie_loc">
                            <option value="C" {{ data.loc is defined and data.loc == 'C' ? 'selected' }}>Cabinet</option>
                            <option value="D" {{ data.loc is defined and data.loc == 'D' ? 'selected' }}>Domiciliu</option>
                        </select>
                    </div>
                    <div class="col-sm-3 mb-3 mb-sm-0">
                        <label for="investigatie_medicTrimitator">Medic trimitator (cauta sau introdu)</label>
                        <div class="input-group date">
                            <input list="list_inv" class="form-control" id="investigatie_medicTrimitator" name="investigatie_medicTrimitator" placeholder="Nume si cod parafa"  value="{{ data.medicTrimitator|default('') }}" />
                            <span id="list_all_inv" class="input-group-append"><span class="input-group-text"><i class="fa fa-arrow-circle-down"></i></span></span>
                            <datalist id="list_inv">
                                {% for medicTrimitator in mediciTrimitatori %}
                                    <option value="{{ medicTrimitator.nume }}"
                                            {{ data.medicTrimitator|default('') == medicTrimitator.nume ? 'selected' }}>
                                        {{ medicTrimitator.nume }}
                                    </option>
                                {% endfor %}
                            </datalist>
                        </div>
                    </div>
                    <div class="col-sm-3 mb-3 mb-sm-0"></div>
                    <div class="col-sm-3 mb-3 mb-sm-0"></div>
                </div>
                <input type="hidden" id="investigatie_id" name="investigatie_id" value="{{ data.id ?? '' }}" />
                <input type="hidden" id="investigatie_pret" name="investigatie_pret" value="{{ data.pretId ?? '' }}" />
            </form>
        </div>
    </div>
</div>
<div class="modal-footer" style="margin-right: 25px;">
    <p class="modal-body rezultat_operatiune" style="display: none; margin-top: 10px; margin-bottom: 10px; font-weight: bold;"></p>
    <label style="color: #AA3333; font-weight: bold; text-align: right;" for="tarif_investigatie">Tarif investigatie</label>
    <input style="width: 55px; border: 1px solid #AA3333; border-radius:5px; text-align: right; font-weight: bold;" id="tarif_investigatie" name="tarif_investigatie" class="input_tarif" value="{{ data.tarif ?? '0' }}" />
    <p style="color: black; margin-right: 10px; margin-left: 5px; border: none;"><b>RON</b></p>
    <button type="button" class="btn btn-primary confirma_investigatie btn_confirma confirma_inv_from_pacient">Salveaza
        <span class="spinner-border spinner-border-sm spinner"style="display: none;" ></span>
    </button>
    <button type="button" class="btn btn-secondary" data-dismiss="modal">Anuleaza</button>
</div>