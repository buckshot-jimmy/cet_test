<div class="modal-header">
    <h5 class="modal-title" id="titlu_view_eval_psiho">Evaluare psihologica: {{ data.denumireServiciu ?? '' }}</h5>
    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
        <span>&times;</span>
    </button>
</div>
<div class="modal-body">
    {% set TIP_EVAL_PSIHO = 2 %}
    <div class="form-group row">
        <div class="col-sm-2 mb-3 mb-sm-0">
            <label for="view_eval_psiho_nr_inreg">Numar inregistrare</label>
            <input type="text" class="form-control" id="view_eval_psiho_nr_inreg" name="view_eval_psiho_nr_inreg" value="{{ data.nrInreg ?? '' }}" disabled>
        </div>
        <div class="col-sm-4 mb-3 mb-sm-0">
            <label for="view_eval_psiho_pacient">Pacient</label>
            <input type="text" class="form-control" id="view_eval_psiho_pacient" name="view_eval_psiho_pacient" value="{{ data.numePacient ?? '' }}" disabled/>
        </div>
        <div class="col-sm-1 mb-3 mb-sm-0">
            <label for="view_eval_psiho_sex">Sex</label>
            <input type="text" class="form-control" id="view_eval_psiho_sex" name="view_eval_psiho_sex" value="{{ data.sex ?? '' }}" disabled />
        </div>
        <div class="col-sm-2 mb-3 mb-sm-0">
            <label for="view_eval_psiho_data_nasterii">Data nasterii</label>
            <input type="text" class="form-control" id="view_eval_psiho_data_nasterii" name="view_eval_psiho_data_nasterii" value="{{ data.dataNasterii ?? '' }}" disabled />
        </div>
        <div class="col-sm-3 mb-3 mb-sm-0">
            <label for="view_eval_psiho_cnp">CNP / CI</label>
            <input type="text" class="form-control" id="view_eval_psiho_cnp" name="view_eval_psiho_cnp" value="{{ data.cnp ?? '' }}" disabled />
        </div>
    </div>
    <div class="form-group row">
        <div class="col-sm-4 dropdown show">
            <label for="view_eval_psiho_medic">Medic</label>
            <select type="text" class="form-control" id="view_eval_psiho_medic" name="view_eval_psiho_medic" disabled>
                <option value="">- Alegeti -</option>
                {% for medic in medici %}
                    <option value="{{ medic.id }}"
                            {{ data.medicId|default('') == medic.id ? 'selected' }}>
                        {{ medic.nume }} {{ medic.prenume }}
                    </option>
                {% endfor %}
            </select>
        </div>
        <div class="col-sm-4 dropdown show">
            <label for="view_eval_psiho_serviciu">Serviciu</label>
            <select type="text" class="form-control" id="view_eval_psiho_serviciu" name="view_eval_psiho_serviciu" disabled>
                <option value="">- Alegeti -</option>
                {% for serviciu in servicii %}
                    {% if serviciu.tip == TIP_EVAL_PSIHO %}
                        <option value="{{ serviciu.id }}"
                                {{ data.serviciuId|default('') == serviciu.id ? 'selected' }}>
                            {{ serviciu.denumire }}
                        </option>
                    {% endif %}
                {% endfor %}
            </select>
        </div>
        <div class="col-sm-4 dropdown show">
            <label for="view_eval_psiho_owner">Owner</label>
            <select type="text" class="form-control" id="view_eval_psiho_owner" name="view_eval_psiho_owner" disabled>
                <option value="">- Alegeti -</option>
                {% for owner in owners %}
                    <option value="{{ owner.id }}"
                            {{ data.ownerId|default('') == owner.id ? 'selected' }}>
                        {{ owner.denumire }}
                    </option>
                {% endfor %}
            </select>
        </div>
    </div>
    <br/>
    <div class="form-group row">
        <div class="col-sm-11 mb-3 mb-sm-0">
            <label for="view_eval_psiho_obiectiv"><b>Obiectivul psihodiagnosticului şi evaluării</b></label>
            <textarea class="form-control preia_eval_psiho" id="view_eval_psiho_obiectiv" name="view_eval_psiho_obiectiv" disabled>{{ data.consultatie ?? '' }}</textarea>
        </div>
        <div class="col-sm-1 mb-3 mb-sm-0" style="display: inline-block;">
            <button type="button"
                    class="btn btn-primary confirma_preia_eval"
                    data-from-eval="#view_eval_psiho_obiectiv"
                    data-to-eval="#eval_psiho_obiectiv">
                Preia
            </button>
        </div>
    </div>
    <br/>
    <div class="form-group row">
        <div class="col-sm-12 mb-3 mb-sm-0">
            <label><b>Descrierea succintă a componentelor psihologice</b></label>
        </div>
    </div>
    <div class="form-group row">
        <div class="col-sm-12 mb-3 mb-sm-0">
            <label><b>Nivel subiectiv/emoţional (inclusiv Satisfacţia/Calitatea vieţii)</b></label>
        </div>
    </div>
    <div class="form-group row">
        <div class="col-sm-6 mb-3 mb-sm-0">
            <label for="view_eval_psiho_subiectiv_ce">Ce s-a evaluat?</label>
            <textarea class="form-control preia_eval_psiho" id="view_eval_psiho_subiectiv_ce" name="view_eval_psiho_subiectiv_ce" disabled>{{ data.evalPsiho.subiectiv_ce ?? '' }}</textarea>
        </div>
        <div class="col-sm-5 mb-3 mb-sm-0">
            <label for="view_eval_psiho_subiectiv_cu_ce">Cu ce s-a evaluat?</label>
            <textarea class="form-control preia_eval_psiho" id="view_eval_psiho_subiectiv_cu_ce" name="view_eval_psiho_subiectiv_cu_ce" disabled>{{ data.evalPsiho.subiectiv_cu_ce ?? '' }}</textarea>
        </div>
        <div class="col-sm-1 mb-3 mb-sm-0" style="display: inline-block;">
            <button type="button"
                    class="btn btn-primary confirma_preia_eval"
                    data-from-eval-ce="#view_eval_psiho_subiectiv_ce"
                    data-from-eval-cu-ce="#view_eval_psiho_subiectiv_cu_ce"
                    data-to-eval-ce="#eval_psiho_subiectiv_ce"
                    data-to-eval-cu-ce="#eval_psiho_subiectiv_cu_ce">
                Preia
            </button>
        </div>
    </div>
    <br/>
    <div class="form-group row">
        <div class="col-sm-12 mb-3 mb-sm-0">
            <label><b>Nivel cognitiv</b></label>
        </div>
    </div>
    <div class="form-group row">
        <div class="col-sm-6 mb-3 mb-sm-0">
            <label for="view_eval_psiho_cognitiv_ce">Ce s-a evaluat?</label>
            <textarea class="form-control preia_eval_psiho" id="view_eval_psiho_cognitiv_ce" name="view_eval_psiho_cognitiv_ce" disabled>{{ data.evalPsiho.cognitiv_ce ?? '' }}</textarea>
        </div>
        <div class="col-sm-5 mb-3 mb-sm-0">
            <label for="view_eval_psiho_cognitiv_cu_ce">Cu ce s-a evaluat?</label>
            <textarea class="form-control preia_eval_psiho" id="view_eval_psiho_cognitiv_cu_ce" name="view_eval_psiho_cognitiv_cu_ce" disabled>{{ data.evalPsiho.cognitiv_cu_ce ?? '' }}</textarea>
        </div>
        <div class="col-sm-1 mb-3 mb-sm-0" style="display: inline-block;">
            <button type="button"
                    class="btn btn-primary confirma_preia_eval"
                    data-from-eval-ce="#view_eval_psiho_cognitiv_ce"
                    data-from-eval-cu-ce="#view_eval_psiho_cognitiv_cu_ce"
                    data-to-eval-ce="#eval_psiho_cognitiv_ce"
                    data-to-eval-cu-ce="#eval_psiho_cognitiv_cu_ce">
                Preia
            </button>
        </div>
    </div>
    <br/>
    <div class="form-group row">
        <div class="col-sm-12 mb-3 mb-sm-0">
            <label><b>Nivel comportamental</b></label>
        </div>
    </div>
    <div class="form-group row">
        <div class="col-sm-6 mb-3 mb-sm-0">
            <label for="view_eval_psiho_comportamental_ce">Ce s-a evaluat?</label>
            <textarea class="form-control preia_eval_psiho" id="view_eval_psiho_comportamental_ce" name="view_eval_psiho_comportamental_ce" disabled>{{ data.evalPsiho.comportamental_ce ?? '' }}</textarea>
        </div>
        <div class="col-sm-5 mb-3 mb-sm-0">
            <label for="view_eval_psiho_comportamental_cu_ce">Cu ce s-a evaluat?</label>
            <textarea class="form-control preia_eval_psiho" id="view_eval_psiho_comportamental_cu_ce" name="view_eval_psiho_comportamental_cu_ce" disabled>{{ data.evalPsiho.comportamental_cu_ce ?? '' }}</textarea>
        </div>
        <div class="col-sm-1 mb-3 mb-sm-0" style="display: inline-block;">
            <button type="button"
                    class="btn btn-primary confirma_preia_eval"
                    data-from-eval-ce="#view_eval_psiho_comportamental_ce"
                    data-from-eval-cu-ce="#view_eval_psiho_comportamental_cu_ce"
                    data-to-eval-ce="#eval_psiho_comportamental_ce"
                    data-to-eval-cu-ce="#eval_psiho_comportamental_cu_ce">
                Preia
            </button>
        </div>
    </div>
    <br/>
    <div class="form-group row">
        <div class="col-sm-12 mb-3 mb-sm-0">
            <label><b>Nivel psihofiziologic</b></label>
        </div>
    </div>
    <div class="form-group row">
        <div class="col-sm-6 mb-3 mb-sm-0">
            <label for="view_eval_psiho_psihofiziologic_ce">Ce s-a evaluat?</label>
            <textarea class="form-control preia_eval_psiho" id="view_eval_psiho_psihofiziologic_ce" name="view_eval_psiho_psihofiziologic_ce" disabled>{{ data.evalPsiho.psihofiziologic_ce ?? '' }}</textarea>
        </div>
        <div class="col-sm-5 mb-3 mb-sm-0">
            <label for="view_eval_psiho_psihofiziologic_cu_ce">Cu ce s-a evaluat?</label>
            <textarea class="form-control preia_eval_psiho" id="view_eval_psiho_psihofiziologic_cu_ce" name="view_eval_psiho_psihofiziologic_cu_ce" disabled>{{ data.evalPsiho.psihofiziologic_cu_ce ?? '' }}</textarea>
        </div>
        <div class="col-sm-1 mb-3 mb-sm-0" style="display: inline-block;">
            <button type="button"
                    class="btn btn-primary confirma_preia_eval"
                    data-from-eval-ce="#view_eval_psiho_psihofiziologic_ce"
                    data-from-eval-cu-ce="#view_eval_psiho_psihofiziologic_cu_ce"
                    data-to-eval-ce="#eval_psiho_psihofiziologic_ce"
                    data-to-eval-cu-ce="#eval_psiho_psihofiziologic_cu_ce">
                Preia
            </button>
        </div>
    </div>
    <br/>
    <div class="form-group row">
        <div class="col-sm-12 mb-3 mb-sm-0">
            <label><b>Nivel de personalitate şi mecanisme defensive/adaptare</b></label>
        </div>
    </div>
    <div class="form-group row">
        <div class="col-sm-6 mb-3 mb-sm-0">
            <label for="view_eval_psiho_personalitate_ce">Ce s-a evaluat?</label>
            <textarea class="form-control preia_eval_psiho" id="view_eval_psiho_personalitate_ce" name="view_eval_psiho_personalitate_ce" disabled>{{ data.evalPsiho.personalitate_ce ?? '' }}</textarea>
        </div>
        <div class="col-sm-5 mb-3 mb-sm-0">
            <label for="view_eval_psiho_personalitate_cu_ce">Cu ce s-a evaluat?</label>
            <textarea class="form-control preia_eval_psiho" id="view_eval_psiho_personalitate_cu_ce" name="view_eval_psiho_personalitate_cu_ce" disabled>{{ data.evalPsiho.personalitate_cu_ce ?? '' }}</textarea>
        </div>
        <div class="col-sm-1 mb-3 mb-sm-0" style="display: inline-block;">
            <button type="button"
                    class="btn btn-primary confirma_preia_eval"
                    data-from-eval-ce="#view_eval_psiho_personalitate_ce"
                    data-from-eval-cu-ce="#view_eval_psiho_personalitate_cu_ce"
                    data-to-eval-ce="#eval_psiho_personalitate_ce"
                    data-to-eval-cu-ce="#eval_psiho_personalitate_cu_ce">
                Preia
            </button>
        </div>
    </div>
    <br/>
    <div class="form-group row">
        <div class="col-sm-12 mb-3 mb-sm-0">
            <label><b>Nivel de relaţionare interpersonală (inclusiv, de cuplu, familie, grup etc.)</b></label>
        </div>
    </div>
    <div class="form-group row">
        <div class="col-sm-6 mb-3 mb-sm-0">
            <label for="view_eval_psiho_relationare_ce">Ce s-a evaluat?</label>
            <textarea class="form-control preia_eval_psiho" id="view_eval_psiho_relationare_ce" name="view_eval_psiho_relationare_ce" disabled>{{ data.evalPsiho.relationare_ce ?? '' }}</textarea>
        </div>
        <div class="col-sm-5 mb-3 mb-sm-0">
            <label for="view_eval_psiho_relationare_cu_ce">Cu ce s-a evaluat?</label>
            <textarea class="form-control preia_eval_psiho" id="view_eval_psiho_relationare_cu_ce" name="view_eval_psiho_relationare_cu_ce" disabled>{{ data.evalPsiho.relationare_cu_ce ?? '' }}</textarea>
        </div>
        <div class="col-sm-1 mb-3 mb-sm-0" style="display: inline-block;">
            <button type="button"
                    class="btn btn-primary confirma_preia_eval"
                    data-from-eval-ce="#view_eval_psiho_relationare_ce"
                    data-from-eval-cu-ce="#view_eval_psiho_relationare_cu_ce"
                    data-to-eval-ce="#eval_psiho_relationare_ce"
                    data-to-eval-cu-ce="#eval_psiho_relationare_cu_ce">
                Preia
            </button>
        </div>
    </div>
    <br/>
    <div class="form-group row">
        <div class="col-sm-11 mb-3 mb-sm-0">
            <label for="view_eval_psiho_concluzie"><b>Concluzii</b></label>
            <textarea class="form-control preia_eval_psiho" id="view_eval_psiho_concluzie" name="view_eval_psiho_concluzie" disabled>{{ data.diagnostic ?? '' }}</textarea>
        </div>
        <div class="col-sm-1 mb-3 mb-sm-0" style="display: inline-block;">
            <button type="button"
                    class="btn btn-primary confirma_preia_eval"
                    data-from-eval="#view_eval_psiho_concluzie"
                    data-to-eval="#eval_psiho_concluzie">
                Preia
            </button>
        </div>
    </div>
    <br/>
    <div class="form-group row">
        <div class="col-sm-11 mb-3 mb-sm-0">
            <label for="view_eval_psiho_recomandari"><b>Recomandari</b></label>
            <textarea class="form-control preia_eval_psiho" id="view_eval_psiho_recomandari" name="view_eval_psiho_recomandari" disabled>{{ data.tratament ?? '' }}</textarea>
        </div>
        <div class="col-sm-1 mb-3 mb-sm-0" style="display: inline-block;">
            <button type="button"
                    class="btn btn-primary confirma_preia_eval"
                    data-from-eval="#view_eval_psiho_recomandari"
                    data-to-eval="#eval_psiho_recomandari">
                Preia
            </button>       
        </div>
    </div>
    <div class="form-group row">
        <div class="col-sm-3 mb-3 mb-sm-0">
            <label for="eval_psiho_loc">Locul evaluarii</label>
            <select type="text" class="form-control" id="eval_psiho_loc" name="eval_psiho_loc">
                <option value="C" {{ data.loc is defined and data.loc == 'C' ? 'selected' }}>Cabinet</option>
                <option value="D" {{ data.loc is defined and data.loc == 'D' ? 'selected' }}>Domiciliu</option>
            </select>
        </div>
        <div class="col-sm-3 mb-3 mb-sm-0">
            <label for="view_eval_psiho_medic_trimitator">Medic trimitator (cauta sau introdu)</label>
            <div class="input-group date">
                <input list="list_cons" class="form-control" id="view_eval_psiho_medic_trimitator" name="view_eval_psiho_medic_trimitator" placeholder="Nume si cod parafa" value="{{ data.medicTrimitator|default('') }}" />
                <span id="list_all_cons" class="input-group-append"><span class="input-group-text"><i class="fa fa-arrow-circle-down"></i></span></span>
                <datalist id="list_cons">
                    {% for medicTrimitator in mediciTrimitatori %}
                        <option value="{{ medicTrimitator.nume }}"
                                {{ data.medicTrimitator|default('') == medicTrimitator.nume ? 'selected' }}>
                            {{ medicTrimitator.nume }}
                        </option>
                    {% endfor %}
                </datalist>
            </div>
        </div>
        <div class="col-sm-3 mb-3 mb-sm-0"></div>
        <div class="col-sm-3 mb-3 mb-sm-0"></div>
    </div>
</div>
<div class="modal-footer">
    <label style="text-align: right; color: #AA3333; font-weight: bold;" for="view_tarif_eval_psiho">Tarif evaluare psihologica</label>
    <input style="width: 55px; border: 1px solid #AA3333; border-radius:5px; text-align: right; font-weight: bold; color: black;" id="view_tarif_eval_psiho" name="view_tarif_eval_psiho" value="{{ data.tarif ?? '0' }}" />
    <p style="color: black; margin-right: 10px; margin-left: 5px; border: none;"><b>RON</b></p>
    <button type="button" class="btn btn-primary confirma_preia_tot">Preia tot</button>
    <button type="button" class="btn btn-secondary" data-dismiss="modal">Anuleaza</button>
</div>