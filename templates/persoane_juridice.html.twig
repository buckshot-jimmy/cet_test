{% extends 'base.html.twig' %}
{% set user = app.user %}
{% set ROL_ADMIN = 'ROLE_Administrator' %}
{% block title %}MIND RESET - Clienti persoane juridice{% endblock %}
{% block tableTitle %}Clienti persoane judirice{% endblock %}
{% block addBtnText %}Adauga{% endblock %}
{% block pjBtn %}
    {% if user.role == ROL_ADMIN %}
        <a href="#" class="btn btn-success btn-icon-split btn-sm add_pj">
            <span class="icon text-white-50">
                <i class="fas fa-plus"></i>
            </span><span class="text">Adauga</span>
        </a>
    {% endif %}
{% endblock %}
{% if user.role != ROL_ADMIN %}
    {% set class = 'no_show' %}
{% else %}
    {% set class = 'add_pj' %}
{% endif %}
{% block classAddBtn %}{{ class }}{% endblock %}
{% block table %}
    <table class="table table-bordered rounded dataTable display nowrap" id="clienti_pj" width="100%" cellspacing="0" role="grid" aria-describedby="dataTable_info" style="width: 100%;"></table>
{% endblock %}
{% block addModal %}
    {% include 'modals/add_edit_pj_modal.html.twig' %}
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('assets/js/persoane_juridice.js') }}"></script>
{% endblock %}