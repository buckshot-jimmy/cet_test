<div class="modal modal_mesaj_admin" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Mesaj informare utilizatori</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="add_mesaj_form">
                    <div class="form-group row">
                        <div class="col-sm-9 mb-3 mb-sm-0">
                            <label for="mesaj">Mesaj</label>
                            <textarea class="form-control" id="mesaj" name="mesaj" placeholder="Mesaj"></textarea>
                        </div>
                        <div class="col-sm-3 mb-3 mb-sm-0" style="margin-top: 45px;">
                            <input id="active" name="active" type="checkbox" data-toggle="toggle" data-on="Activ" data-off="Inactiv" data-width="100">
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <p class="rezultat_operatiune modal-body"></p>
                <button type="button" class="btn btn-primary confirma_mesaj">Confirma
                    <span class="spinner-border spinner-border-sm spinner" style="display: none;"></span>
                </button>
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Anuleaza</button>
            </div>
        </div>
    </div>
</div>