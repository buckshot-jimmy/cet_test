<div class="modal email_factura_modal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Trimite factura pe email</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="email_factura_form">
                    <input class="form-control" type="email" id="email_trimite_factura" name="email_trimite_factura" placeholder="Email" required>
                    <input type="hidden" id="factura_id" name="factura_id">
                </form>
            </div>
            <div class="modal-footer">
                <p class="rezultat_operatiune modal-body twig-style-012"></p>
                <button type="button" class="btn btn-primary confirma_trimite_factura_email">Trimite
                    <span class="spinner-border spinner-border-sm spinner twig-style-003"></span>
                </button>
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Anuleaza</button>
            </div>
        </div>
    </div>
</div>