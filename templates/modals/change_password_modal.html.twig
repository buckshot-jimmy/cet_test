<div class="modal change_password_modal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Schimba parola</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="change_password_form">
                    <div class="form-group row">
                        <div class="col-sm-12 mb-3 mb-sm-0">
                            <label for="change_password">Parola</label>
                            <input type="text" class="form-control" id="change_password" name="change_password" placeholder="Parola">
                        </div>
                    </div>
                    <div class="form-group row">
                        <div class="col-sm-12 mb-3 mb-sm-0">
                            <label for="change_confirm_password">Reintroduceti parola</label>
                            <input type="text" class="form-control" id="change_confirm_password" name="change_confirm_password" placeholder="Reintroduceti parola">
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <p class="modal-body rezultat_operatiune" style="display: none; margin-top: 10px; margin-bottom: 10px; font-weight: bold;"></p>
                <input type="hidden" id="logged_user_id" value="{{ app.user ? app.user.id : "" }}"/>
                <button type="button" class="btn btn-primary confirma_change_password">Confirma
                    <span class="spinner-border spinner-border-sm spinner" style="display: none;"></span>
                </button>
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Anuleaza</button>
            </div>
        </div>
    </div>
</div>