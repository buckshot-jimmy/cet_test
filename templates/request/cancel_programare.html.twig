<!DOCTYPE html>
<html lang="en">
<link href="{{ asset('assets/sigla.ico') }}" rel="icon" type="image/icon" />
<link href="{{ asset('assets/css/all.min.css') }}" rel="stylesheet" type="text/css">
<link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">
<link href="{{ asset('assets/css/sb-admin-2.min.css') }}" rel="stylesheet" type="text/css" />
<link href="{{ asset('assets/css/custom.css') }}" rel="stylesheet" type="text/css">

<body class="bg-gradient-primary" id="page-top">
<div class="container-fluid d-flex justify-content-center align-items-center vh-100">
    {{ form_start(form, {
        'action': path('pacient_anuleaza_programare'),
        'attr': {
            'id': 'anuleaza_programare',
            'class': 'text-center p-4 rounded',
            'style': 'background-color: darkblue; width: 100%; max-width: 400px;'
        }
    }) }}

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }}" role="alert" style="text-align: center; margin: 0 16px 12px;">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="mb-3" style="font-weight: bold; color: white;">
        Anuleaza programarea din {{ data }}, {{ ora }}
    </div>

    <div class="mb-3">
        {{ form_widget(form.pacient_anuleaza_programare) }}
    </div>

    <input type="hidden" name="programareId" value="{{ programareId }}">

    {{ form_end(form) }}
</div>
</body>
</html>
