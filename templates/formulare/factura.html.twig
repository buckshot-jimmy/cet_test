<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Factura</title>
    <link href="{{ asset('assets/css/twig-extracted.css') }}" rel="stylesheet" type="text/css">
    <link href="{{ asset('assets/css/twig-templates-extracted.css') }}" rel="stylesheet" type="text/css">
</head>
<body class="tpl-formulare-factura">
<div class="container">
    <div class="row">
        <div class="fact-box">
            <div class="twig-style-037"></div>
            <strong>Furnizor:</strong><br>
            {{ data.furnizor.denumire }}<br>
            Nr. Reg. Com: {{ data.furnizor.regCom }}<br>
            Cap. social: {{ data.furnizor.capitalSocial }}<br>
            CUI: {{ data.furnizor.cui }}<br>
            Sediul: {{ data.furnizor.adresa }}<br>
            IBAN: {{ data.furnizor.contBancar }}<br>
            Banca: {{ data.furnizor.banca }}
        </div>
        <div class="fact-box">
            <img src="{{ asset('assets/sigla_pdf.png') }}" alt="MIND RESET" class="twig-style-038">
            <h1 class="factura-title">Factura</h1>
            <div class="invoice-info">
                Nr. factura: {{ data.nrFactura }}<br>
                Data: {{ data.dataFactura }}
            </div>
        </div>
        <div class="fact-box fact-box-right">
            <div class="twig-style-037"></div>
            <strong>Cumparator:</strong><br>
            {{ data.cumparator.nume is defined ? data.cumparator.nume ~ ' ' ~ data.cumparator.prenume : data.cumparator.denumire }} <br>
            {{ data.cumparator.adresa }} <br>
            {{ data.cumparator.cnp is defined ? 'CNP ' ~ data.cumparator.cnp : 'CUI ' ~ data.cumparator.cui }}
        </div>
    </div>
    <p class="twig-style-039">Cota TVA: „Scutit de TVA conform art. 292 Cod Fiscal”</p>
    <table class="servicii-factura">
        <tr>
            <th>Nr. crt.</th>
            <th>Denumirea serviciilor</th>
            <th>U.M.</th>
            <th>Cantitate</th>
            <th>Pret unitar - lei</th>
            <th>Valoare - lei</th>
        </tr>
        {% for crt, serviciu in data.consultatii %}
            <tr>
                <td>{{ crt + 1 }}</td>
                <td>{{ serviciu.pret.serviciu.denumire ~ ' / ' ~ serviciu.dataConsultatie | date("d-m-Y") }}</td>
                <td>BUC</td>
                <td>1</td>
                <td>{{ serviciu.tarif }}</td>
                <td>{{ serviciu.tarif }}</td>
            </tr>
        {% endfor %}
    </table>
    {% if data.stornata %}
        <p class="row">Storno la factura {{ data.stornata }}</p>
    {% endif %}
</div>
<div class="fact-footer">
    <table class="footer-table">
        <tr>
            <td rowspan="2" class="twig-style-040">
                <strong>Semnatura si stampila furnizorului</strong><br><br>
            </td>
            <td rowspan="2" class="twig-style-041">
                <strong>Date privind expeditia</strong><br><br>
                Numele delegatului: {{ data.consultatii[0].pacient.nume ~ ' ' ~  data.consultatii[0].pacient.prenume}}<br>
                Buletin/C.I.: {{ data.consultatii[0].pacient.ci }}, eliberata de: {{ data.consultatii[0].pacient.ciEliberat }}<br>
                Mijlocul de transport: <br>
                Data si ora expedierii: {{ "now" | date_modify('+3 hours') | date("d-m-Y H:i") }}<br>
                Semnaturile: <br>&nbsp;<br>&nbsp;<br>
            </td>
            <td rowspan="2" class="twig-style-042">
                <strong>Semnatura de primire:</strong><br>
            </td>
            <td class="twig-style-043">
                <strong>Total de plata - lei:</strong>
                <br>&nbsp;<br><br>
                <h2><strong>{{ data.total }}</strong></h2>
            </td>
        </tr>
        <tr>
            <td class="twig-style-044">
                <strong>Termen de plata:</strong><br>&nbsp;<br>
                <p>{{ data.scadenta|date("d-m-Y") }}</p>
            </td>
        </tr>
    </table>
</div>
</body>
</html>