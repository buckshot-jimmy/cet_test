{% extends 'base.html.twig' %}

{% block title %}MIND RESET{% endblock %}

{% block body %}
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-4">
        <div class="card o-hidden border-0 shadow-lg my-5">
          <div class="card-body p-0">
            <!-- Nested Row within Card Body -->
            <div class="row">
              <div class="col-lg-12">
                <div class="p-5">
                  <div class="text-center">
                    {% for label, messages in flashes %}
                      {% for message in messages %}
                        <div class="alert alert-{{ label }}" role="alert" style="text-align: center; margin-bottom: 20px;">
                          {{ message }}
                        </div>
                      {% endfor %}
                    {% endfor %}
                    <h1 class="h4 text-gray-900 mb-4">Bun venit!</h1>
                  </div>
                  <form method="post" id="login_form">
                    {% if error %}
                      <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                    {% endif %}

                    {% if app.user %}
                      <div class="mb-3">
                        Esti logat cu {{ app.user.username }}. <a href="{{ path('app_logout') }}">Iesi din aplicatie</a>
                        sau <a href="{{ path('admin') }}">Mergi la pagina principala</a>
                      </div>
                    {% endif %}
                    <div class="form-group">
                      <label for="username" class="sr-only"></label>
                      <input class="form-control form-control-user" id="username" name="username" aria-describedby="usernameHelp" placeholder="Nume utilizator" required>
                    </div>
                    <div class="form-group">
                      <label for="password" class="sr-only"></label>
                      <input type="password" class="form-control form-control-user" id="password" name="password" placeholder="Parola" required>
                    </div>
                    <input type="checkbox" id="_remember_me" name="_remember_me">
                    <label for="_remember_me" class="checkmark-style">
                      <span class="check-box"></span>
                      <span class="label-text">Remember me</span>
                    </label>
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}" >
                    <button class="btn btn-primary btn-user btn-block" type="submit">
                      Login
                    </button>
                  </form>
                  <div class="text-center" style="margin-top: 20px;">
                    <a href="{{ path('forgot_password_email') }}">Ai uitat parola?</a>
                  </div>
                  <hr>
                  <div style="height: 100px; margin-top: 40px;">
                    <img class="sigla_login" src="{{ asset('assets/sigla.png') }}" alt="MIND RESET">
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}