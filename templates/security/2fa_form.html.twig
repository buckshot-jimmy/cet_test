<!DOCTYPE html>
<html lang="en">
<link href="{{ asset('assets/sigla.ico') }}" rel="icon" type="image/icon" />
<link href="{{ asset('assets/css/all.min.css') }}" rel="stylesheet" type="text/css">
<link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">
<link href="{{ asset('assets/css/sb-admin-2.min.css') }}" rel="stylesheet" type="text/css" />
<link href="{{ asset('assets/css/custom.css') }}" rel="stylesheet" type="text/css">

<body class="bg-gradient-primary" id="page-top">
<div class="container-fluid d-flex justify-content-center align-items-center vh-100">
    <div class="text-center p-4 rounded" style="background-color: darkblue; width: 100%; max-width: 400px;">
        <form id="trimite_cod"
              action="{{ path('2fa_login_check') }}"
              method="post">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'danger'
                    ? 'danger' : (label == 'warning'
                    ? 'warning' : 'success') }} mb-3">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            {% if authenticationError is defined and authenticationError %}
                <div class="alert alert-danger mb-3">
                    Codul introdus este incorect in baza de date.
                </div>
            {% endif %}

            <div class="mb-3" style="font-weight: bold; color: white;">
                Introdu codul primit pe email
            </div>

            <div class="mb-3">
                <label for="2fa_code">
                    <input type="text" name="_auth_code" id="_auth_code" class="form-control" required placeholder="Cod">
                </label>
            </div>
            <div class="d-flex justify-content-center">
                <button type="submit" class="btn btn-light">Login</button>
            </div>
        </form>
        <div class="d-flex justify-content-center" style="margin-top: 10px; gap: 10px;">
            <form action="{{ path('2fa_resend') }}" method="post">
                <input type="hidden" name="_token" value="{{ csrf_token('2fa_resend') }}">
                <button type="submit" class="btn btn-info">Retrimite cod</button>
            </form>
            <form action="{{ path('app_2fa_cancel') }}" method="post">
                <input type="hidden" name="_token" value="{{ csrf_token('2fa_cancel') }}">
                <button type="submit" class="btn btn-info">Renunta</button>
            </form>
        </div>
    </div>
</div>
<script src="{{ asset('assets/js/app_js/jquery.min.js') }}"></script>
<script src="{{ asset('assets/js/app_js/bootstrap.bundle.min.js') }}"></script>
<script src="{{ asset('assets/js/app_js/jquery.easing.js') }}"></script>
<script src="{{ asset('assets/js/app_js/sb-admin-2.min.js') }}"></script>
<script src="{{ asset('assets/js/app_js/jquery.validate.js') }}"></script>
<script src="{{ asset('assets/js/app_js/jquery_extend.js') }}"></script>
<script src="{{ asset('assets/js/forgot_password.js') }}"></script>
<div id="global-alert-container"></div>
</body>
</html>
