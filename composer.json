{
    "type": "project",
    "license": "proprietary",
    "prefer-stable": true,
    "require": {
        "php": "8.2",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-pdo": "*",
        "amphp/http-client": "5.3.4",
        "beberlei/doctrineextensions": "^1.5",
        "doctrine/doctrine-bundle": "^2.7",
        "doctrine/doctrine-migrations-bundle": "^3.2",
        "doctrine/orm": "^2.12",
        "mpdf/mpdf": "^8.2",
        "pagerfanta/doctrine-orm-adapter": "^3.6",
        "paragonie/sodium_compat": "*",
        "phpdocumentor/reflection-docblock": "^5.6",
        "phpstan/phpdoc-parser": "^1.9",
        "scheb/2fa-email": "^7.13",
        "sensio/framework-extra-bundle": "^6.0",
        "symfony/asset": "6.4",
        "symfony/cache": "^7.4",
        "symfony/console": "^6.4.24",
        "symfony/dotenv": "6.4",
        "symfony/event-dispatcher": "6.4.24",
        "symfony/filesystem": "6.4.24",
        "symfony/finder": "6.4.24",
        "symfony/form": "6.4",
        "symfony/framework-bundle": "^6.4",
        "symfony/http-client": "6.4.15",
        "symfony/http-foundation": "^7.4",
        "symfony/mailer": "6.4",
        "symfony/mercure": "*",
        "symfony/mercure-bundle": "*",
        "symfony/monolog-bundle": "^3.0",
        "symfony/options-resolver": "6.4.24",
        "symfony/process": "^6.4.3",
        "symfony/property-access": "^6.4.3",
        "symfony/property-info": "^6.4.3",
        "symfony/proxy-manager-bridge": "^6.4",
        "symfony/security-bundle": "6.4.10",
        "symfony/security-http": "^6.4.30",
        "symfony/serializer": "6.4",
        "symfony/translation": "6.4.31",
        "symfony/validator": "6.4.31",
        "symfony/web-profiler-bundle": "6.4",
        "symfony/yaml": "^6.4",
        "symfonycasts/reset-password-bundle": "^1.24",
        "twig/extra-bundle": "^2.12|^3.0",
        "twig/twig": "^2.12|^3.0"
    },
    "config": {
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "platform": {
            "php": "8.2"
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": true,
            "require": "6.4",
            "docker": true
        }
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^3.6",
        "friendsofphp/php-cs-fixer": "3.90",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^4.0",
        "symfony/browser-kit": "6.4",
        "symfony/css-selector": "6.4",
        "symfony/debug-bundle": "6.4",
        "symfony/maker-bundle": "^1.66",
        "symfony/phpunit-bridge": "^8.0",
        "symfony/stopwatch": "6.4.24",
        "symfony/twig-bundle": "6.4"
    }
}
